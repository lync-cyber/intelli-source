<html>
<body style="font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;max-width:640px;margin:0 auto;padding:16px;line-height:1.6;color:#1a1a1a">
{% set item = bundle.sections[0].items[0] if bundle.sections and bundle.sections[0].items else None %}
{% if item %}
<h1 style="font-size:22px;margin:0 0 12px">{{ item.title }}</h1>
{% if item.summary %}
<p style="font-size:16px;color:#333;margin:0 0 16px"><strong>TL;DR</strong> {{ item.summary }}</p>
{% endif %}
{% if item.key_points %}
<ul style="padding-left:20px;margin:0 0 16px">
{% for kp in item.key_points %}
<li style="margin:4px 0">{{ kp }}</li>
{% endfor %}
</ul>
{% endif %}
{% if item.body_text %}
<div style="color:#444;margin:0 0 16px">{{ item.body_text }}</div>
{% endif %}
{% if bundle.timeline %}
<h3 style="font-size:15px;color:#666">时间线</h3>
<ul style="padding-left:20px">
{% for e in bundle.timeline %}
<li style="margin:4px 0">{{ e.date }} — {{ e.event }}</li>
{% endfor %}
</ul>
{% endif %}
{% if item.source_url %}
<p style="margin-top:16px"><a href="{{ item.source_url }}" style="color:#2563eb">{{ item.source_name or item.source_url }}</a></p>
{% endif %}
{% endif %}
</body>
</html>
