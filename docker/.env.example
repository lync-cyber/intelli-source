# IntelliSource — Docker environment variable reference
# Copy to docker/.env and fill in real values before running docker compose.
# Lines starting with # are comments. Never commit docker/.env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Full async DSN used by the API, worker, beat, and migration services.
# When set, overrides the per-service IS_DB_* defaults in docker-compose.yml.
IS_DATABASE_URL=postgresql+asyncpg://intellisource:intellisource@db:5432/intellisource

# PostgreSQL credentials (used by docker-compose db service and DSN defaults)
IS_DB_USER=intellisource
IS_DB_PASSWORD=intellisource
IS_DB_NAME=intellisource

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
IS_REDIS_URL=redis://redis:6379/0
IS_CELERY_BROKER_URL=redis://redis:6379/0
IS_CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---------------------------------------------------------------------------
# API authentication
# ---------------------------------------------------------------------------
# Bearer token required for all /api/v1/* requests.
IS_API_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# LLM / litellm
# ---------------------------------------------------------------------------
# Path to the LLM model routing config (relative to /app in container).
IS_LLM_CONFIG_PATH=config/llm_models.yaml

# Provider API keys — pass whichever providers are configured in llm_models.yaml.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=

# ---------------------------------------------------------------------------
# Source / Subscription config directories
# ---------------------------------------------------------------------------
IS_SOURCE_CONFIG_DIR=config/sources
IS_SUBSCRIPTION_CONFIG_DIR=config/subscriptions

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
IS_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Distribution channels (optional — leave blank to disable; unconfigured
# channels are soft-disabled at startup and log a warning, no hard-fail)
# ---------------------------------------------------------------------------
# Recommended: WeWork (企业微信) — no 48h customer-window constraint,
# supports markdown, direct contact-book delivery, no public-account filing
# required. WeChat (公众号) is supported but requires 公众号 备案 + 年审 and
# is bound by the 48h customer-service interaction window.

# WeWork (企业微信)  ── recommended primary push channel
IS_WEWORK_CORP_ID=
IS_WEWORK_CORP_SECRET=
IS_WEWORK_AGENT_ID=
# WeCom encrypted webhook (required only when wework webhook is enabled and
# you want AES-CBC encrypted callbacks; corp_id below mirrors IS_WEWORK_CORP_ID)
IS_WECOM_TOKEN=
IS_WECOM_ENCODING_AES_KEY=
IS_WECOM_CORP_ID=

# WeChat Official Account  ── optional, requires 公众号 备案 + 年审
IS_WECHAT_APP_ID=
IS_WECHAT_APP_SECRET=
IS_WECHAT_WEBHOOK_TOKEN=

# Email (SMTP)  ── optional, useful for local dev via mailhog/mailpit
# IS_SMTP_USE_TLS defaults to true; set to false for plain SMTP (mailhog/mailpit dev).
IS_SMTP_HOST=
IS_SMTP_USER=
IS_SMTP_PASSWORD=
IS_SMTP_PORT=587
IS_SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Set to "1" to enable push-optimize deduplication.
IS_PUSH_OPTIMIZE_ENABLED=0

# Set to "1" to disable Celery beat scheduler (useful when running beat externally).
IS_BEAT_DISABLED=0
