# IntelliSource — Docker environment variable reference
# Copy to docker/.env and fill in real values before running docker compose.
# Lines starting with # are comments. Never commit docker/.env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Full async DSN used by the API, worker, beat, and migration services.
# When set, overrides the per-service IS_DB_* defaults in docker-compose.yml.
# Keep the password here identical to IS_DB_PASSWORD below (the db service
# authenticates with IS_DB_PASSWORD; the app connects via this DSN).
IS_DATABASE_URL=postgresql+asyncpg://intellisource:change-me-strong-db-password@db:5432/intellisource

# PostgreSQL credentials (used by docker-compose db service and DSN defaults).
# `intellisource init` auto-generates a strong IS_DB_PASSWORD; only edit by hand
# if you copy this file manually instead of running init.
IS_DB_USER=intellisource
IS_DB_PASSWORD=change-me-strong-db-password
IS_DB_NAME=intellisource

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
# redis runs with --requirepass, so the password below must appear in every URL.
# `intellisource init` auto-generates IS_REDIS_PASSWORD and the three URLs; only
# edit by hand if you copy this file manually instead of running init.
IS_REDIS_PASSWORD=change-me-strong-redis-password
IS_REDIS_URL=redis://:change-me-strong-redis-password@redis:6379/0
IS_CELERY_BROKER_URL=redis://:change-me-strong-redis-password@redis:6379/0
IS_CELERY_RESULT_BACKEND=redis://:change-me-strong-redis-password@redis:6379/1

# ---------------------------------------------------------------------------
# API authentication
# ---------------------------------------------------------------------------
# Bearer token required for all /api/v1/* requests.
IS_API_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# Embedding service (HuggingFace TEI / BGE-M3)
# ---------------------------------------------------------------------------
# When IS_EMBEDDING_API_BASE is set, the pipeline uses the OpenAI-compatible
# /v1/embeddings endpoint of the local TEI service (litellm openai/bge-m3 +
# api_base).  Leave blank (or omit) to fall back to keyword-only search via
# zhparser FTS — no hard failure, graceful degradation.
#
# CPU deployment (default in docker-compose.yml):
#   IS_EMBEDDING_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.6
#
# GPU deployment — requires the gpu override file AND a CUDA-enabled image:
#   docker compose -f docker-compose.yml -f docker-compose.gpu.yml up
#   IS_EMBEDDING_IMAGE=ghcr.io/huggingface/text-embeddings-inference:1.6
#
# Exact image tags and /v1/embeddings route should be confirmed against the
# current TEI release notes during the PRE-DEPLOY-WALKTHROUGH.
IS_EMBEDDING_API_BASE=http://embedding/v1
IS_EMBEDDING_API_KEY=tei
IS_EMBEDDING_DIMENSION=1024
IS_EMBEDDING_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.6

# ---------------------------------------------------------------------------
# LLM / litellm
# ---------------------------------------------------------------------------
# Path to the LLM model routing config (relative to /app in container).
IS_LLM_CONFIG_PATH=config/llm_models.yaml

# Provider API keys — pass whichever providers are configured in llm_models.yaml.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=

# ---------------------------------------------------------------------------
# Source / Subscription config directories
# ---------------------------------------------------------------------------
IS_SOURCE_CONFIG_DIR=config/sources
IS_SUBSCRIPTION_CONFIG_DIR=config/subscriptions

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
IS_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Distribution channels (optional — leave blank to disable; unconfigured
# channels are soft-disabled at startup and log a warning, no hard-fail)
# ---------------------------------------------------------------------------
# Recommended: WeWork (企业微信) — no 48h customer-window constraint,
# supports markdown, direct contact-book delivery, no public-account filing
# required. WeChat (公众号) is supported but requires 公众号 备案 + 年审 and
# is bound by the 48h customer-service interaction window.

# WeWork (企业微信)  ── recommended primary push channel
IS_WEWORK_CORP_ID=
IS_WEWORK_CORP_SECRET=
IS_WEWORK_AGENT_ID=
# WeCom encrypted webhook (required only when wework webhook is enabled and
# you want AES-CBC encrypted callbacks; corp_id below mirrors IS_WEWORK_CORP_ID)
IS_WECOM_TOKEN=
IS_WECOM_ENCODING_AES_KEY=
IS_WECOM_CORP_ID=

# WeChat Official Account  ── optional, requires 公众号 备案 + 年审
IS_WECHAT_APP_ID=
IS_WECHAT_APP_SECRET=
IS_WECHAT_WEBHOOK_TOKEN=

# Email (SMTP)  ── optional, useful for local dev via mailhog/mailpit
# Port↔TLS mapping: 465↔use_tls=true (implicit TLS), 587↔use_tls=false (STARTTLS),
# 1025/25↔use_tls=false (local plain dev, e.g. mailhog/mailpit).
IS_SMTP_HOST=
IS_SMTP_USER=
IS_SMTP_PASSWORD=
IS_SMTP_PORT=587
IS_SMTP_USE_TLS=false

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Set to "1" to enable push-optimize deduplication.
IS_PUSH_OPTIMIZE_ENABLED=0

# Set to "1" to disable Celery beat scheduler (useful when running beat externally).
IS_BEAT_DISABLED=0
