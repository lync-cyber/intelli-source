{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "allow": [
      "Bash(git diff*)",
      "Bash(uv pip install*)",
      "Bash(yarn test*)",
      "Bash(yarn install*)",
      "Bash(bash .claude/scripts/setup-penpot-mcp.sh --ensure)",
      "WebSearch",
      "Bash(bun test*)",
      "Bash(bun run *)",
      "Bash(bunx *)",
      "Bash(uv sync*)",
      "Bash(go mod *)",
      "Bash(python .claude/scripts/*.py*)",
      "Bash(git add*)",
      "Bash(uv run *)",
      "Bash(npm test*)",
      "Bash(mkdir *)",
      "Bash(dotnet build*)",
      "Bash(dotnet restore*)",
      "Bash(ruff *)",
      "Bash(pnpm run *)",
      "Bash(bun install*)",
      "Bash(pnpm exec *)",
      "Bash(pnpm install*)",
      "Bash(go test *)",
      "Bash(git commit*)",
      "Bash(pnpm test*)",
      "Bash(npm run *)",
      "Bash(yarn run *)",
      "Bash(dotnet format*)",
      "Bash(ls *)",
      "Bash(npm install*)",
      "Bash(python -m pytest*)",
      "Bash(dotnet test*)",
      "Bash(go build *)",
      "Bash(git status*)",
      "Bash(git checkout -- docs/*)",
      "Bash(python -m pip install*)",
      "Bash(npx prettier*)",
      "Bash(python .claude/skills/*/scripts/*.py*)",
      "Bash(npx eslint*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rmdir /s /q *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.guard_dangerous"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.log_agent_dispatch"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.validate_agent_result"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.lint_format"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.detect_correction"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.detect_review_flag"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.notify_done"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.notify_permission"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python -m cataforge.hook.scripts.session_context"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "mcpServers": {},
  "autoCompact": true
}
